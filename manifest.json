{
  "manifest_version": 3,
  "name": "CellPeek",
  "version": "0.1.1",
  "description": "Preview Feishu/Lark sheet cell content in a right side panel.",
  "permissions": ["activeTab", "scripting", "sidePanel", "clipboardRead", "clipboardWrite"],
  "host_permissions": [
    "https://feishu.cn/*",
    "https://*.feishu.cn/*",
    "https://larksuite.com/*",
    "https://*.larksuite.com/*",
    "https://*.larkoffice.com/*"
  ],
  "action": {
    "default_title": "Open CellPeek"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://feishu.cn/*",
        "https://*.feishu.cn/*",
        "https://larksuite.com/*",
        "https://*.larksuite.com/*",
        "https://*.larkoffice.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
